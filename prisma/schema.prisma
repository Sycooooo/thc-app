generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  password        String
  avatar          String?
  xp              Int       @default(0)
  currency        Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate  DateTime?
  createdAt       DateTime  @default(now())
  hideStats       Boolean   @default(false)
  hideOnline      Boolean   @default(false)
  rankPoints      Int       @default(0)
  seasonNumber    Int       @default(1)

  memberships     UserColoc[]
  assignedTasks   Task[]    @relation("AssignedTasks")
  completedTasks  TaskHistory[]
  scores          Score[]
  items           UserItem[]
  achievements    UserAchievement[]
  createdEvents   CalendarEvent[] @relation("CreatedEvents")
  createdBoardItems BoardItem[]  @relation("CreatedBoardItems")
  notifications     Notification[]
  messages          Message[]
  paidExpenses      Expense[]      @relation("PaidExpenses")
  expenseSplits     ExpenseSplit[] @relation("ExpenseSplits")
  avatarConfig      AvatarConfig?
  placedFurniture   PlacedFurniture[]
  seasonRecords     SeasonRecord[]
  spotifyAccount    SpotifyAccount?
  musicStories      MusicStory[]
  habits            Habit[]
  habitLogs         HabitLog[]
  penaltyLogs       PenaltyLog[]
}

model Colocation {
  id                  String    @id @default(cuid())
  name                String
  inviteCode          String    @unique @default(cuid())
  maxQuestsPerDay     Int       @default(2)
  questsSetupDone     Boolean   @default(false)
  lastQuestGen        DateTime?
  createdAt           DateTime  @default(now())

  members         UserColoc[]
  tasks           Task[]
  scores          Score[]
  colocTemplates  ColocTemplate[]
  affinities      MemberAffinity[]
  events          CalendarEvent[]
  boardItems      BoardItem[]
  notifications   Notification[]
  messages        Message[]
  menus           WeeklyMenu[]
  expenses        Expense[]
  placedFurniture PlacedFurniture[]

  musicStories    MusicStory[]
  habits          Habit[]
  penaltyLogs     PenaltyLog[]
}

model UserColoc {
  id             String    @id @default(cuid())
  role           String    @default("member")
  joinedAt       DateTime  @default(now())

  // Away / Vacances
  isAway         Boolean   @default(false)
  awayStartDate  DateTime?
  awayConfirmed  Boolean   @default(false)

  // Pénalités
  penaltyXpMult  Float     @default(1.0)
  penaltyUntil   DateTime?
  lazyBadge      Boolean   @default(false)
  lazyTasksDone  Int       @default(0)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  difficulty  String    @default("medium")
  category    String?   // "cleaning", "cooking", "sport", "maintenance", "admin"
  room        String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  recurrence  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo  User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])

  history     TaskHistory[]
}

model TaskHistory {
  id          String    @id @default(cuid())
  completedAt DateTime  @default(now())

  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  completedById String
  completedBy User    @relation(fields: [completedById], references: [id])
}

model Score {
  id      String @id @default(cuid())
  points  Int    @default(0)

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId String
  coloc   Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

// === Boutique ===

model ShopItem {
  id                String    @id @default(cuid())
  name              String
  description       String?
  price             Int
  type              String    // "avatar_part", "decoration", "badge_style"
  rarity            String    @default("common") // "common", "rare", "epic", "legendary"
  imageUrl          String?
  layer             String?   // "hair", "eyes", "top", "bottom", "shoes", "accessory"
  spriteName        String?   // nom du fichier sprite (ex: "hoodie-black")
  isFree            Boolean   @default(false)
  colorHex          String?
  depthCm           Int?
  furnitureCategory String?
  heightCm          Int?
  modelKey          String?
  roomConstraint    String?
  widthCm           Int?
  createdAt         DateTime  @default(now())

  buyers            UserItem[]
  placedFurniture   PlacedFurniture[]
}

model UserItem {
  id          String    @id @default(cuid())
  purchasedAt DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId      String
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

// === Avatar Pixel Art ===

model AvatarConfig {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  skinTone     String  @default("medium")  // "light", "medium", "tan", "dark", "deep"
  body         String  @default("default")
  hair         String?                      // spriteName ou null
  eyes         String  @default("default")
  top          String?
  bottom       String?
  shoes        String?
  accessory    String?
  savedOutfit  Json?   // sauvegarde config avant strip (streak=0), restaurée après 3 tâches
}

// === Achievements ===

model Achievement {
  id          String    @id @default(cuid())
  name        String
  description String
  icon        String    // emoji
  condition   String    // ex: "tasks_completed:1", "streak:7", "hard_tasks:10"
  reward      Int       @default(0) // coins gagnes en debloquant

  unlockedBy  UserAchievement[]
}

model UserAchievement {
  id          String    @id @default(cuid())
  unlockedAt  DateTime  @default(now())

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// === Notifications ===

model Notification {
  id        String    @id @default(cuid())
  type      String    // "task_assigned", "task_completed", "new_event", "new_board_item"
  message   String
  read      Boolean   @default(false)
  link      String?   // URL vers la page concernée
  createdAt DateTime  @default(now())

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Tableau d'affichage ===

model BoardItem {
  id          String    @id @default(cuid())
  content     String
  type        String    @default("text") // "text", "image", "link"
  color       String    @default("yellow") // "yellow", "pink", "blue", "green", "purple", "orange", "teal", "red"
  size        String    @default("normal") // "normal", "large"
  imageUrl    String?
  linkUrl     String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation("CreatedBoardItems", fields: [createdById], references: [id])
}

// === Calendrier partagé ===

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String    @default("indigo") // indigo, red, green, amber, purple
  createdAt   DateTime  @default(now())

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation("CreatedEvents", fields: [createdById], references: [id])
}

// === Templates de quêtes ===

model QuestTemplate {
  id            String    @id @default(cuid())
  title         String
  description   String?
  category      String    // "cleaning", "cooking", "sport", "maintenance", "admin"
  room          String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  difficulty    String    @default("medium")
  recurrence    String    @default("weekly") // "daily", "weekly", "monthly"

  colocTemplates ColocTemplate[]
}

// === Quêtes actives par coloc ===
// Lie un template (ou une quête custom) à une colocation

model ColocTemplate {
  id          String    @id @default(cuid())
  isActive    Boolean   @default(true)
  isCustom    Boolean   @default(false)

  // Si basé sur un template global
  templateId  String?
  template    QuestTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Champs pour quêtes custom (ou override du template)
  title       String?
  description String?
  category    String?
  room        String?
  difficulty  String?
  recurrence  String?

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([templateId, colocId])
}

// === Affinités membres ===
// Un membre peut avoir une préférence pour certaines catégories

model MemberAffinity {
  id        String @id @default(cuid())
  weight    Int    @default(1) // plus le poids est élevé, plus souvent il reçoit cette catégorie

  userId    String
  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
  category  String // "cleaning", "cooking", "sport", "maintenance", "admin"

  @@unique([userId, colocId, category])
}

// === Menus & Courses IA ===

model WeeklyMenu {
  id            String   @id @default(cuid())
  weekStart     DateTime // Lundi de la semaine
  nbPersons     Int      @default(2)
  restrictions  String?  // "vegetarien", "sans gluten", etc.
  budget        String   @default("moyen") // "economique", "moyen", "genereux"
  meals         String   // JSON string des 7 jours de repas
  shoppingList  String?  // JSON string de la liste de courses
  createdAt     DateTime @default(now())

  colocId       String
  coloc         Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Dépenses (Tricount) ===

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  description String
  category    String   @default("other") // "courses", "loyer", "sorties", "menage", "other"
  paidById    String
  paidBy      User     @relation("PaidExpenses", fields: [paidById], references: [id], onDelete: Cascade)
  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id          String   @id @default(cuid())
  amount      Float    // Montant dû par cette personne
  userId      String
  user        User     @relation("ExpenseSplits", fields: [userId], references: [id], onDelete: Cascade)
  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([userId, expenseId])
}

// === Saisons Ranking ===

model SeasonRecord {
  id            String   @id @default(cuid())
  seasonNumber  Int
  finalRank     String   // ex: "midnight_1", "neon_3", "ethereal"
  finalPoints   Int
  rewardType    String?  // "badge", "border", "title"
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonNumber])
}

// === Meubles placés ===

model PlacedFurniture {
  id         String   @id @default(cuid())
  posX       Float
  posZ       Float
  rotation   Float    @default(0)
  roomId     String
  colocId    String
  coloc      Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
  placedById String
  placedBy   User     @relation(fields: [placedById], references: [id], onDelete: Cascade)
  itemId     String
  item       ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([colocId])
}

// === Spotify ===

model SpotifyAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyUserId String   @unique
  displayName   String?
  profileUrl    String?
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  linkedAt      DateTime @default(now())
}

model MusicStory {
  id         String   @id @default(cuid())
  trackId    String
  trackName  String
  artistName String
  albumArt   String
  spotifyUrl String
  caption    String?
  reactions  Json     @default("{}")
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  colocId String
  coloc   Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Habits ===

model Habit {
  id          String    @id @default(cuid())
  title       String
  description String?
  icon        String    @default("✅")
  difficulty  String    @default("medium")
  block       String    @default("anytime")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  date      DateTime
  completed Boolean  @default(true)

  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId, date])
}

// === Chat ===

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // "text", "gif"
  imageUrl  String?  // URL du GIF
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Pénalités ===

model PenaltyLog {
  id        String   @id @default(cuid())
  type      String   // "expired_task", "inactivity_tax", "week_inactive", "habit_miss", "rank_demotion", "items_stripped"
  amount    Int      // XP/coins perdus ou points déduits
  message   String
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Briefings Stratégiques ===

model Briefing {
  id        String   @id @default(cuid())
  date      DateTime @unique
  score     Float
  rawHtml   String
  sections  Json
  sources   Json?
  evalText  String?
  createdAt DateTime @default(now())
}

// === Away Votes ===

model AwayVote {
  id        String   @id @default(cuid())
  approved  Boolean
  voterId   String
  targetId  String
  colocId   String
  createdAt DateTime @default(now())

  @@unique([voterId, targetId, colocId])
}
