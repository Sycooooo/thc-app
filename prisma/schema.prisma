generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  password        String
  avatar          String?
  xp              Int       @default(0)
  currency        Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate  DateTime?
  createdAt       DateTime  @default(now())

  memberships     UserColoc[]
  assignedTasks   Task[]    @relation("AssignedTasks")
  completedTasks  TaskHistory[]
  scores          Score[]
  items           UserItem[]
  achievements    UserAchievement[]
  createdEvents   CalendarEvent[] @relation("CreatedEvents")
  createdBoardItems BoardItem[]  @relation("CreatedBoardItems")
  notifications     Notification[]
  messages          Message[]
  paidExpenses      Expense[]      @relation("PaidExpenses")
  expenseSplits     ExpenseSplit[] @relation("ExpenseSplits")
  avatarConfig      AvatarConfig?
}

model Colocation {
  id                  String    @id @default(cuid())
  name                String
  inviteCode          String    @unique @default(cuid())
  maxQuestsPerDay     Int       @default(2)
  questsSetupDone     Boolean   @default(false)
  lastQuestGen        DateTime?
  createdAt           DateTime  @default(now())

  members         UserColoc[]
  tasks           Task[]
  scores          Score[]
  colocTemplates  ColocTemplate[]
  affinities      MemberAffinity[]
  events          CalendarEvent[]
  boardItems      BoardItem[]
  notifications   Notification[]
  messages        Message[]
  menus           WeeklyMenu[]
  expenses        Expense[]
}

model UserColoc {
  id          String    @id @default(cuid())
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  difficulty  String    @default("medium")
  category    String?   // "cleaning", "cooking", "sport", "maintenance", "admin"
  room        String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  recurrence  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo  User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])

  history     TaskHistory[]
}

model TaskHistory {
  id          String    @id @default(cuid())
  completedAt DateTime  @default(now())

  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  completedById String
  completedBy User    @relation(fields: [completedById], references: [id])
}

model Score {
  id      String @id @default(cuid())
  points  Int    @default(0)

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId String
  coloc   Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

// === Boutique ===

model ShopItem {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Int
  type        String    // "avatar_part", "decoration", "badge_style"
  rarity      String    @default("common") // "common", "rare", "epic", "legendary"
  imageUrl    String?
  layer       String?   // "hair", "eyes", "top", "bottom", "shoes", "accessory"
  spriteName  String?   // nom du fichier sprite (ex: "hoodie-black")
  isFree      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  buyers      UserItem[]
}

model UserItem {
  id          String    @id @default(cuid())
  purchasedAt DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId      String
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

// === Avatar Pixel Art ===

model AvatarConfig {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  skinTone  String  @default("medium")  // "light", "medium", "tan", "dark", "deep"
  body      String  @default("default")
  hair      String?                      // spriteName ou null
  eyes      String  @default("default")
  top       String?
  bottom    String?
  shoes     String?
  accessory String?
}

// === Achievements ===

model Achievement {
  id          String    @id @default(cuid())
  name        String
  description String
  icon        String    // emoji
  condition   String    // ex: "tasks_completed:1", "streak:7", "hard_tasks:10"
  reward      Int       @default(0) // coins gagnes en debloquant

  unlockedBy  UserAchievement[]
}

model UserAchievement {
  id          String    @id @default(cuid())
  unlockedAt  DateTime  @default(now())

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// === Notifications ===

model Notification {
  id        String    @id @default(cuid())
  type      String    // "task_assigned", "task_completed", "new_event", "new_board_item"
  message   String
  read      Boolean   @default(false)
  link      String?   // URL vers la page concernée
  createdAt DateTime  @default(now())

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Tableau d'affichage ===

model BoardItem {
  id          String    @id @default(cuid())
  content     String
  type        String    @default("text") // "text", "image", "link"
  color       String    @default("yellow") // "yellow", "pink", "blue", "green", "purple", "orange", "teal", "red"
  size        String    @default("normal") // "normal", "large"
  imageUrl    String?
  linkUrl     String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation("CreatedBoardItems", fields: [createdById], references: [id])
}

// === Calendrier partagé ===

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String    @default("indigo") // indigo, red, green, amber, purple
  createdAt   DateTime  @default(now())

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation("CreatedEvents", fields: [createdById], references: [id])
}

// === Templates de quêtes ===

model QuestTemplate {
  id            String    @id @default(cuid())
  title         String
  description   String?
  category      String    // "cleaning", "cooking", "sport", "maintenance", "admin"
  room          String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  difficulty    String    @default("medium")
  recurrence    String    @default("weekly") // "daily", "weekly", "monthly"

  colocTemplates ColocTemplate[]
}

// === Quêtes actives par coloc ===
// Lie un template (ou une quête custom) à une colocation

model ColocTemplate {
  id          String    @id @default(cuid())
  isActive    Boolean   @default(true)
  isCustom    Boolean   @default(false)

  // Si basé sur un template global
  templateId  String?
  template    QuestTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Champs pour quêtes custom (ou override du template)
  title       String?
  description String?
  category    String?
  room        String?
  difficulty  String?
  recurrence  String?

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([templateId, colocId])
}

// === Affinités membres ===
// Un membre peut avoir une préférence pour certaines catégories

model MemberAffinity {
  id        String @id @default(cuid())
  weight    Int    @default(1) // plus le poids est élevé, plus souvent il reçoit cette catégorie

  userId    String
  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
  category  String // "cleaning", "cooking", "sport", "maintenance", "admin"

  @@unique([userId, colocId, category])
}

// === Menus & Courses IA ===

model WeeklyMenu {
  id            String   @id @default(cuid())
  weekStart     DateTime // Lundi de la semaine
  nbPersons     Int      @default(2)
  restrictions  String?  // "vegetarien", "sans gluten", etc.
  budget        String   @default("moyen") // "economique", "moyen", "genereux"
  meals         String   // JSON string des 7 jours de repas
  shoppingList  String?  // JSON string de la liste de courses
  createdAt     DateTime @default(now())

  colocId       String
  coloc         Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}

// === Dépenses (Tricount) ===

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  description String
  category    String   @default("other") // "courses", "loyer", "sorties", "menage", "other"
  paidById    String
  paidBy      User     @relation("PaidExpenses", fields: [paidById], references: [id], onDelete: Cascade)
  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id          String   @id @default(cuid())
  amount      Float    // Montant dû par cette personne
  userId      String
  user        User     @relation("ExpenseSplits", fields: [userId], references: [id], onDelete: Cascade)
  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([userId, expenseId])
}

// === Chat ===

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // "text", "gif"
  imageUrl  String?  // URL du GIF
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId   String
  coloc     Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)
}
